+++ b/hooks/useBrandKit.ts
@@ -0,0 +1,45 @@
+import { useState } from 'react';
+import type { BrandKit } from '../types';
+
+const BRAND_KIT_KEY = 'studioai_brand_kit';
+
+const defaultBrandKit: BrandKit = {
+  logo: null,
+  headshot: null,
+  primaryColor: '#0A84FF',
+  secondaryColor: '#1a1a2e',
+  agentName: '',
+  brokerageName: '',
+  phone: '',
+  email: '',
+  website: '',
+  tagline: '',
+};
+
+export function useBrandKit() {
+  const [brandKit, setBrandKit] = useState<BrandKit>(() => {
+    try {
+      const stored = localStorage.getItem(BRAND_KIT_KEY);
+      return stored ? { ...defaultBrandKit, ...JSON.parse(stored) } : defaultBrandKit;
+    } catch {
+      return defaultBrandKit;
+    }
+  });
+
+  const updateBrandKit = (partial: Partial<BrandKit>) => {
+    setBrandKit((prev) => {
+      const updated = { ...prev, ...partial };
+      localStorage.setItem(BRAND_KIT_KEY, JSON.stringify(updated));
+      return updated;
+    });
+  };
+
+  const resetBrandKit = () => {
+    localStorage.removeItem(BRAND_KIT_KEY);
+    setBrandKit(defaultBrandKit);
+  };
+
+  const hasBrandKit = !!(brandKit.agentName && brandKit.logo);
+
+  return { brandKit, updateBrandKit, resetBrandKit, hasBrandKit };
+}
