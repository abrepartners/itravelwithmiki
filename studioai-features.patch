diff --git a/utils/imageExport.ts b/utils/imageExport.ts
new file mode 100644
index 0000000..291f90c
--- /dev/null
+++ b/utils/imageExport.ts
@@ -0,0 +1,203 @@
+import JSZip from 'jszip';
+import { saveAs } from 'file-saver';
+import type { WatermarkConfig } from '../types';
+
+// ─── Helpers ────────────────────────────────────────────────────────────────
+
+function loadImage(src: string): Promise<HTMLImageElement> {
+  return new Promise((resolve, reject) => {
+    const img = new Image();
+    img.onload = () => resolve(img);
+    img.onerror = reject;
+    img.src = src;
+  });
+}
+
+function blobToDataUrl(blob: Blob): Promise<string> {
+  return new Promise((resolve, reject) => {
+    const reader = new FileReader();
+    reader.onload = () => resolve(reader.result as string);
+    reader.onerror = reject;
+    reader.readAsDataURL(blob);
+  });
+}
+
+// ─── Core exports ───────────────────────────────────────────────────────────
+
+/**
+ * Convert a base64 data-URL (e.g. "data:image/png;base64,…") to a Blob.
+ */
+export function base64ToBlob(dataUrl: string): Blob {
+  const [header, b64] = dataUrl.split(',');
+  const mime = header.match(/:(.*?);/)?.[1] || 'image/png';
+  const bytes = atob(b64);
+  const arr = new Uint8Array(bytes.length);
+  for (let i = 0; i < bytes.length; i++) arr[i] = bytes.charCodeAt(i);
+  return new Blob([arr], { type: mime });
+}
+
+/**
+ * Resize an image blob to target dimensions. Re-encoding strips EXIF.
+ */
+export async function resizeImage(
+  blob: Blob,
+  width: number,
+  height: number,
+  quality = 0.92,
+): Promise<Blob> {
+  const url = await blobToDataUrl(blob);
+  const img = await loadImage(url);
+  const canvas = document.createElement('canvas');
+  canvas.width = width;
+  canvas.height = height;
+  const ctx = canvas.getContext('2d')!;
+  ctx.drawImage(img, 0, 0, width, height);
+  return new Promise((resolve, reject) => {
+    canvas.toBlob(
+      (b) => (b ? resolve(b) : reject(new Error('Resize failed'))),
+      'image/jpeg',
+      quality,
+    );
+  });
+}
+
+/**
+ * Strip EXIF data by re-encoding through canvas.
+ */
+export async function stripExif(blob: Blob): Promise<Blob> {
+  const url = await blobToDataUrl(blob);
+  const img = await loadImage(url);
+  const canvas = document.createElement('canvas');
+  canvas.width = img.naturalWidth;
+  canvas.height = img.naturalHeight;
+  const ctx = canvas.getContext('2d')!;
+  ctx.drawImage(img, 0, 0);
+  return new Promise((resolve, reject) => {
+    canvas.toBlob(
+      (b) => (b ? resolve(b) : reject(new Error('Strip EXIF failed'))),
+      'image/jpeg',
+      0.95,
+    );
+  });
+}
+
+/**
+ * Add a watermark (text or logo) to an image blob.
+ */
+export async function addWatermark(
+  blob: Blob,
+  config: WatermarkConfig,
+): Promise<Blob> {
+  const url = await blobToDataUrl(blob);
+  const img = await loadImage(url);
+  const canvas = document.createElement('canvas');
+  canvas.width = img.naturalWidth;
+  canvas.height = img.naturalHeight;
+  const ctx = canvas.getContext('2d')!;
+  ctx.drawImage(img, 0, 0);
+
+  const opacity = config.opacity ?? 0.7;
+  const padding = Math.round(img.naturalWidth * 0.02);
+  const isRight = (config.position ?? 'bottom-right') === 'bottom-right';
+
+  if (config.type === 'logo' && config.logoBase64) {
+    const logo = await loadImage(config.logoBase64);
+    const maxH = Math.round(img.naturalHeight * 0.08);
+    const scale = maxH / logo.naturalHeight;
+    const lw = logo.naturalWidth * scale;
+    const lh = maxH;
+    const x = isRight ? canvas.width - lw - padding : padding;
+    const y = canvas.height - lh - padding;
+
+    ctx.globalAlpha = opacity;
+    ctx.drawImage(logo, x, y, lw, lh);
+    ctx.globalAlpha = 1;
+  } else {
+    const text = config.text || 'Virtually Staged';
+    const fontSize = Math.max(14, Math.round(img.naturalWidth * 0.018));
+    ctx.font = `bold ${fontSize}px Inter, system-ui, sans-serif`;
+    const metrics = ctx.measureText(text);
+    const tw = metrics.width;
+    const th = fontSize;
+
+    const bgPad = Math.round(fontSize * 0.5);
+    const x = isRight ? canvas.width - tw - padding - bgPad : padding;
+    const y = canvas.height - th - padding - bgPad;
+
+    ctx.globalAlpha = opacity * 0.6;
+    ctx.fillStyle = '#000';
+    ctx.beginPath();
+    ctx.roundRect(x, y, tw + bgPad * 2, th + bgPad * 2, fontSize * 0.3);
+    ctx.fill();
+
+    ctx.globalAlpha = opacity;
+    ctx.fillStyle = '#fff';
+    ctx.fillText(text, x + bgPad, y + bgPad + th * 0.85);
+    ctx.globalAlpha = 1;
+  }
+
+  return new Promise((resolve, reject) => {
+    canvas.toBlob(
+      (b) => (b ? resolve(b) : reject(new Error('Watermark failed'))),
+      'image/jpeg',
+      0.95,
+    );
+  });
+}
+
+/**
+ * Crop an image blob to a target aspect ratio (center crop).
+ */
+export async function cropToAspect(
+  blob: Blob,
+  aspectWidth: number,
+  aspectHeight: number,
+): Promise<Blob> {
+  const url = await blobToDataUrl(blob);
+  const img = await loadImage(url);
+  const srcRatio = img.naturalWidth / img.naturalHeight;
+  const targetRatio = aspectWidth / aspectHeight;
+
+  let sx = 0, sy = 0, sw = img.naturalWidth, sh = img.naturalHeight;
+  if (srcRatio > targetRatio) {
+    sw = Math.round(img.naturalHeight * targetRatio);
+    sx = Math.round((img.naturalWidth - sw) / 2);
+  } else {
+    sh = Math.round(img.naturalWidth / targetRatio);
+    sy = Math.round((img.naturalHeight - sh) / 2);
+  }
+
+  const canvas = document.createElement('canvas');
+  canvas.width = sw;
+  canvas.height = sh;
+  const ctx = canvas.getContext('2d')!;
+  ctx.drawImage(img, sx, sy, sw, sh, 0, 0, sw, sh);
+
+  return new Promise((resolve, reject) => {
+    canvas.toBlob(
+      (b) => (b ? resolve(b) : reject(new Error('Crop failed'))),
+      'image/jpeg',
+      0.95,
+    );
+  });
+}
+
+/**
+ * Package multiple files into a zip and return the zip blob.
+ */
+export async function exportAsZip(
+  files: { name: string; blob: Blob }[],
+): Promise<Blob> {
+  const zip = new JSZip();
+  for (const f of files) {
+    zip.file(f.name, f.blob);
+  }
+  return zip.generateAsync({ type: 'blob' });
+}
+
+/**
+ * Trigger a browser download for a blob.
+ */
+export function downloadBlob(blob: Blob, filename: string): void {
+  saveAs(blob, filename);
+}
