diff --git a/components/BrandKit.tsx b/components/BrandKit.tsx
new file mode 100644
index 0000000..b005416
--- /dev/null
+++ b/components/BrandKit.tsx
@@ -0,0 +1,211 @@
+import React, { useRef, useState } from 'react';
+import { Upload, Trash2, Save, User, Building2, Phone, Mail, Globe, Quote, Palette, Check } from 'lucide-react';
+import type { BrandKit as BrandKitType } from '../types';
+
+interface BrandKitProps {
+  brandKit: BrandKitType;
+  onUpdate: (partial: Partial<BrandKitType>) => void;
+  onReset: () => void;
+}
+
+const ImageUploadZone: React.FC<{
+  label: string;
+  value: string | null;
+  onUpload: (base64: string) => void;
+  onClear: () => void;
+}> = ({ label, value, onUpload, onClear }) => {
+  const inputRef = useRef<HTMLInputElement>(null);
+
+  const handleFile = (e: React.ChangeEvent<HTMLInputElement>) => {
+    const file = e.target.files?.[0];
+    if (!file) return;
+    const reader = new FileReader();
+    reader.onload = () => onUpload(reader.result as string);
+    reader.readAsDataURL(file);
+    e.target.value = '';
+  };
+
+  return (
+    <div className="space-y-2">
+      <label className="text-xs font-semibold uppercase tracking-[0.1em] text-[var(--color-text)]">
+        {label}
+      </label>
+      {value ? (
+        <div className="relative group rounded-xl overflow-hidden border border-[var(--color-border)] bg-black aspect-square w-24">
+          <img src={value} alt={label} className="w-full h-full object-contain p-2" />
+          <button
+            type="button"
+            onClick={onClear}
+            className="absolute inset-0 bg-black/70 opacity-0 group-hover:opacity-100 transition-all flex items-center justify-center"
+          >
+            <Trash2 size={16} className="text-[var(--color-accent)]" />
+          </button>
+        </div>
+      ) : (
+        <button
+          type="button"
+          onClick={() => inputRef.current?.click()}
+          className="w-24 aspect-square rounded-xl border-2 border-dashed border-[var(--color-border)] hover:border-[var(--color-primary)] bg-black/50 flex flex-col items-center justify-center gap-1.5 transition-all"
+        >
+          <Upload size={16} className="text-[var(--color-text)]" />
+          <span className="text-[10px] text-[var(--color-text)]">Upload</span>
+        </button>
+      )}
+      <input ref={inputRef} type="file" accept="image/*" onChange={handleFile} className="hidden" />
+    </div>
+  );
+};
+
+const BrandKitPanel: React.FC<BrandKitProps> = ({ brandKit, onUpdate, onReset }) => {
+  const [saved, setSaved] = useState(false);
+
+  const handleSave = () => {
+    setSaved(true);
+    setTimeout(() => setSaved(false), 2000);
+  };
+
+  const field = (
+    icon: React.ReactNode,
+    label: string,
+    key: keyof BrandKitType,
+    placeholder: string,
+    type = 'text',
+  ) => (
+    <div className="space-y-1.5">
+      <label className="text-xs font-semibold uppercase tracking-[0.1em] text-[var(--color-text)] flex items-center gap-1.5">
+        {icon} {label}
+      </label>
+      <input
+        type={type}
+        value={(brandKit[key] as string) || ''}
+        onChange={(e) => onUpdate({ [key]: e.target.value })}
+        placeholder={placeholder}
+        className="w-full rounded-lg border border-[var(--color-border)] bg-black px-3 py-2 text-sm text-[var(--color-ink)] placeholder:text-zinc-600 focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] transition"
+      />
+    </div>
+  );
+
+  return (
+    <div className="space-y-5">
+      <div className="flex items-center justify-between">
+        <div>
+          <h3 className="font-display text-lg font-bold text-[var(--color-ink)]">Brand Kit</h3>
+          <p className="text-xs text-[var(--color-text)] mt-0.5">Your branding appears on exports and collateral.</p>
+        </div>
+      </div>
+
+      {/* Image uploads */}
+      <div className="premium-surface rounded-xl p-4">
+        <p className="text-xs font-semibold uppercase tracking-[0.1em] text-[var(--color-text)] mb-3">Brand Assets</p>
+        <div className="flex gap-4">
+          <ImageUploadZone
+            label="Logo"
+            value={brandKit.logo}
+            onUpload={(b64) => onUpdate({ logo: b64 })}
+            onClear={() => onUpdate({ logo: null })}
+          />
+          <ImageUploadZone
+            label="Headshot"
+            value={brandKit.headshot}
+            onUpload={(b64) => onUpdate({ headshot: b64 })}
+            onClear={() => onUpdate({ headshot: null })}
+          />
+        </div>
+      </div>
+
+      {/* Colors */}
+      <div className="premium-surface rounded-xl p-4">
+        <p className="text-xs font-semibold uppercase tracking-[0.1em] text-[var(--color-text)] mb-3 flex items-center gap-1.5">
+          <Palette size={12} /> Brand Colors
+        </p>
+        <div className="flex gap-4">
+          <div className="space-y-1.5">
+            <label className="text-[10px] text-[var(--color-text)]">Primary</label>
+            <div className="flex items-center gap-2">
+              <input
+                type="color"
+                value={brandKit.primaryColor}
+                onChange={(e) => onUpdate({ primaryColor: e.target.value })}
+                className="h-8 w-8 rounded-lg border border-[var(--color-border)] bg-transparent cursor-pointer"
+              />
+              <span className="text-xs font-mono text-[var(--color-text)]">{brandKit.primaryColor}</span>
+            </div>
+          </div>
+          <div className="space-y-1.5">
+            <label className="text-[10px] text-[var(--color-text)]">Secondary</label>
+            <div className="flex items-center gap-2">
+              <input
+                type="color"
+                value={brandKit.secondaryColor}
+                onChange={(e) => onUpdate({ secondaryColor: e.target.value })}
+                className="h-8 w-8 rounded-lg border border-[var(--color-border)] bg-transparent cursor-pointer"
+              />
+              <span className="text-xs font-mono text-[var(--color-text)]">{brandKit.secondaryColor}</span>
+            </div>
+          </div>
+        </div>
+      </div>
+
+      {/* Text fields */}
+      <div className="premium-surface rounded-xl p-4 space-y-3">
+        <p className="text-xs font-semibold uppercase tracking-[0.1em] text-[var(--color-text)] mb-1">Agent Details</p>
+        {field(<User size={12} />, 'Agent Name', 'agentName', 'Jane Smith')}
+        {field(<Building2 size={12} />, 'Brokerage', 'brokerageName', 'Compass Real Estate')}
+        {field(<Phone size={12} />, 'Phone', 'phone', '(555) 123-4567', 'tel')}
+        {field(<Mail size={12} />, 'Email', 'email', 'jane@compass.com', 'email')}
+        {field(<Globe size={12} />, 'Website', 'website', 'janesmith.com', 'url')}
+        {field(<Quote size={12} />, 'Tagline', 'tagline', 'Your dream home awaits')}
+      </div>
+
+      {/* Actions */}
+      <div className="flex gap-2">
+        <button
+          type="button"
+          onClick={handleSave}
+          className="cta-primary flex-1 rounded-xl py-2.5 text-sm font-semibold inline-flex items-center justify-center gap-2"
+        >
+          {saved ? <><Check size={14} /> Saved</> : <><Save size={14} /> Save Brand Kit</>}
+        </button>
+        <button
+          type="button"
+          onClick={onReset}
+          className="cta-secondary rounded-xl px-4 py-2.5 text-sm font-medium inline-flex items-center gap-2"
+        >
+          <Trash2 size={14} /> Clear
+        </button>
+      </div>
+
+      {/* Preview card */}
+      {brandKit.agentName && (
+        <div className="subtle-card rounded-xl p-4">
+          <p className="text-[10px] uppercase tracking-widest text-[var(--color-text)] mb-3">Preview</p>
+          <div className="flex items-center gap-3">
+            {brandKit.headshot ? (
+              <img src={brandKit.headshot} alt="Headshot" className="w-10 h-10 rounded-full object-cover ring-2 ring-[var(--color-border)]" />
+            ) : (
+              <div className="w-10 h-10 rounded-full bg-[var(--color-bg-deep)] flex items-center justify-center">
+                <User size={16} className="text-[var(--color-text)]" />
+              </div>
+            )}
+            <div className="min-w-0">
+              <p className="text-sm font-semibold text-[var(--color-ink)] truncate">{brandKit.agentName}</p>
+              {brandKit.brokerageName && (
+                <p className="text-xs text-[var(--color-text)] truncate">{brandKit.brokerageName}</p>
+              )}
+            </div>
+            {brandKit.logo && (
+              <img src={brandKit.logo} alt="Logo" className="ml-auto h-8 object-contain opacity-70" />
+            )}
+          </div>
+          {brandKit.tagline && (
+            <p className="mt-2 text-xs italic text-[var(--color-text)] border-t border-[var(--color-border)] pt-2">
+              "{brandKit.tagline}"
+            </p>
+          )}
+        </div>
+      )}
+    </div>
+  );
+};
+
+export default BrandKitPanel;
