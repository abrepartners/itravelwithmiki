+++ b/components/ListingDescription.tsx
@@ -0,0 +1,270 @@
+import React, { useState } from 'react';
+import { X, Copy, Check, FileText, Sparkles, RefreshCcw } from 'lucide-react';
+import { generateListingDescriptions } from '../services/geminiService';
+import type { PropertyDetails, ListingDescriptions } from '../types';
+
+type Tone = 'luxury' | 'casual' | 'investment';
+
+const TONE_META: Record<Tone, { label: string; emoji: string; color: string }> = {
+  luxury: { label: 'Luxury', emoji: '', color: 'var(--color-primary)' },
+  casual: { label: 'Casual', emoji: '', color: '#30D158' },
+  investment: { label: 'Investment', emoji: '', color: '#FF9F0A' },
+};
+
+const MLS_LIMITS = [
+  { label: 'Generic', max: 1000, color: '#30D158' },
+  { label: 'Realtor.com', max: 4000, color: '#FF9F0A' },
+  { label: 'Zillow', max: 5000, color: '#0A84FF' },
+];
+
+function charCountColor(len: number): string {
+  if (len <= 1000) return '#30D158';
+  if (len <= 4000) return '#FF9F0A';
+  if (len <= 5000) return '#0A84FF';
+  return '#FF375F';
+}
+
+interface ListingDescriptionProps {
+  imageBase64: string;
+  roomType: string;
+  onClose: () => void;
+  onRequireKey: () => void;
+}
+
+const ListingDescription: React.FC<ListingDescriptionProps> = ({
+  imageBase64,
+  roomType,
+  onClose,
+  onRequireKey,
+}) => {
+  const [details, setDetails] = useState<PropertyDetails>({});
+  const [agentNotes, setAgentNotes] = useState('');
+  const [descriptions, setDescriptions] = useState<ListingDescriptions | null>(null);
+  const [activeTone, setActiveTone] = useState<Tone>('luxury');
+  const [isGenerating, setIsGenerating] = useState(false);
+  const [copied, setCopied] = useState<Tone | null>(null);
+  const [error, setError] = useState('');
+
+  const handleGenerate = async () => {
+    setIsGenerating(true);
+    setError('');
+    try {
+      const result = await generateListingDescriptions(imageBase64, roomType, details, agentNotes || undefined);
+      setDescriptions(result);
+    } catch (err: any) {
+      if (err.message === 'API_KEY_REQUIRED' || err.message?.includes('API_KEY_INVALID')) {
+        onRequireKey();
+      } else {
+        setError(err?.message || 'Generation failed. Please try again.');
+      }
+    } finally {
+      setIsGenerating(false);
+    }
+  };
+
+  const handleCopy = async (tone: Tone) => {
+    if (!descriptions) return;
+    try {
+      await navigator.clipboard.writeText(descriptions[tone]);
+      setCopied(tone);
+      setTimeout(() => setCopied(null), 2000);
+    } catch {
+      // fallback
+      const ta = document.createElement('textarea');
+      ta.value = descriptions[tone];
+      document.body.appendChild(ta);
+      ta.select();
+      document.execCommand('copy');
+      document.body.removeChild(ta);
+      setCopied(tone);
+      setTimeout(() => setCopied(null), 2000);
+    }
+  };
+
+  const updateField = (key: keyof PropertyDetails, value: string) => {
+    setDetails((prev) => ({
+      ...prev,
+      [key]: ['beds', 'baths', 'sqft', 'price'].includes(key)
+        ? value ? Number(value) : undefined
+        : value || undefined,
+    }));
+  };
+
+  const activeText = descriptions?.[activeTone] || '';
+
+  return (
+    <div className="fixed inset-0 z-[100] grid place-items-center modal-overlay p-4 animate-fade-in">
+      <div className="modal-panel w-full max-w-lg rounded-2xl p-6 animate-scale-in max-h-[90vh] overflow-y-auto scrollbar-hide">
+        {/* Header */}
+        <div className="flex items-start justify-between mb-5">
+          <div>
+            <span className="feature-badge feature-badge-primary mb-2">
+              <FileText size={13} /> Listing Copy
+            </span>
+            <h3 className="font-display text-xl font-bold text-[var(--color-ink)]">
+              AI Listing Descriptions
+            </h3>
+            <p className="text-xs text-[var(--color-text)] mt-1">
+              Generate MLS-ready copy in 3 professional tones.
+            </p>
+          </div>
+          <button
+            type="button"
+            onClick={onClose}
+            className="rounded-lg p-2 text-[var(--color-text)] transition hover:bg-[var(--color-bg)]"
+          >
+            <X size={16} />
+          </button>
+        </div>
+
+        {/* Property details form */}
+        <div className="premium-surface rounded-xl p-4 mb-4 space-y-2.5">
+          <p className="text-xs font-semibold uppercase tracking-[0.1em] text-[var(--color-text)]">
+            Property Details <span className="font-normal opacity-60">(optional)</span>
+          </p>
+          <input
+            type="text"
+            placeholder="Address"
+            value={details.address || ''}
+            onChange={(e) => updateField('address', e.target.value)}
+            className="w-full rounded-lg border border-[var(--color-border)] bg-black px-3 py-2 text-sm text-[var(--color-ink)] placeholder:text-zinc-600 focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] transition"
+          />
+          <div className="grid grid-cols-4 gap-2">
+            <input
+              type="number"
+              placeholder="Beds"
+              value={details.beds ?? ''}
+              onChange={(e) => updateField('beds', e.target.value)}
+              className="w-full rounded-lg border border-[var(--color-border)] bg-black px-2.5 py-2 text-sm text-[var(--color-ink)] placeholder:text-zinc-600 focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] transition"
+            />
+            <input
+              type="number"
+              placeholder="Baths"
+              value={details.baths ?? ''}
+              onChange={(e) => updateField('baths', e.target.value)}
+              className="w-full rounded-lg border border-[var(--color-border)] bg-black px-2.5 py-2 text-sm text-[var(--color-ink)] placeholder:text-zinc-600 focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] transition"
+            />
+            <input
+              type="number"
+              placeholder="Sq Ft"
+              value={details.sqft ?? ''}
+              onChange={(e) => updateField('sqft', e.target.value)}
+              className="w-full rounded-lg border border-[var(--color-border)] bg-black px-2.5 py-2 text-sm text-[var(--color-ink)] placeholder:text-zinc-600 focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] transition"
+            />
+            <input
+              type="number"
+              placeholder="Price"
+              value={details.price ?? ''}
+              onChange={(e) => updateField('price', e.target.value)}
+              className="w-full rounded-lg border border-[var(--color-border)] bg-black px-2.5 py-2 text-sm text-[var(--color-ink)] placeholder:text-zinc-600 focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] transition"
+            />
+          </div>
+          <textarea
+            placeholder="Agent notes (e.g. recently renovated kitchen, near top-rated schools...)"
+            value={agentNotes}
+            onChange={(e) => setAgentNotes(e.target.value)}
+            rows={2}
+            className="w-full rounded-lg border border-[var(--color-border)] bg-black px-3 py-2 text-sm text-[var(--color-ink)] placeholder:text-zinc-600 focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] transition resize-none"
+          />
+        </div>
+
+        {/* Generate button */}
+        <button
+          type="button"
+          onClick={handleGenerate}
+          disabled={isGenerating}
+          className="cta-primary w-full rounded-xl py-3 text-sm font-semibold inline-flex items-center justify-center gap-2 disabled:opacity-50 mb-4"
+        >
+          {isGenerating ? (
+            <>
+              <Sparkles size={15} className="animate-pulse" /> Generating 3 Tones...
+            </>
+          ) : descriptions ? (
+            <>
+              <RefreshCcw size={15} /> Regenerate All
+            </>
+          ) : (
+            <>
+              <Sparkles size={15} /> Generate Descriptions
+            </>
+          )}
+        </button>
+
+        {error && (
+          <p className="text-xs text-[var(--color-accent)] mb-3 text-center">{error}</p>
+        )}
+
+        {/* Results */}
+        {descriptions && (
+          <div className="space-y-3">
+            {/* Tone tabs */}
+            <div className="flex bg-[var(--color-bg-deep)] rounded-lg p-0.5">
+              {(Object.keys(TONE_META) as Tone[]).map((tone) => (
+                <button
+                  key={tone}
+                  type="button"
+                  onClick={() => setActiveTone(tone)}
+                  className={`flex-1 px-3 py-1.5 rounded-md text-xs font-semibold transition-all ${
+                    activeTone === tone
+                      ? 'bg-[rgba(10,132,255,0.15)] border border-[rgba(10,132,255,0.3)]'
+                      : 'text-[var(--color-text)] hover:text-white'
+                  }`}
+                  style={activeTone === tone ? { color: TONE_META[tone].color } : undefined}
+                >
+                  {TONE_META[tone].emoji} {TONE_META[tone].label}
+                </button>
+              ))}
+            </div>
+
+            {/* Description output */}
+            <div className="premium-surface rounded-xl p-4">
+              <p className="text-sm text-[var(--color-ink)] leading-relaxed whitespace-pre-wrap">
+                {activeText}
+              </p>
+            </div>
+
+            {/* Char count + MLS badges */}
+            <div className="flex items-center justify-between">
+              <div className="flex items-center gap-2">
+                <span
+                  className="text-xs font-mono font-bold"
+                  style={{ color: charCountColor(activeText.length) }}
+                >
+                  {activeText.length.toLocaleString()} chars
+                </span>
+                <div className="flex gap-1.5">
+                  {MLS_LIMITS.map((limit) => (
+                    <span
+                      key={limit.label}
+                      className={`text-[10px] font-semibold px-1.5 py-0.5 rounded-md border ${
+                        activeText.length <= limit.max
+                          ? 'border-[rgba(48,209,88,0.3)] text-[#30D158] bg-[rgba(48,209,88,0.08)]'
+                          : 'border-[rgba(255,55,95,0.3)] text-[#FF375F] bg-[rgba(255,55,95,0.08)]'
+                      }`}
+                    >
+                      {limit.label} {activeText.length <= limit.max ? '\u2713' : '\u2717'}
+                    </span>
+                  ))}
+                </div>
+              </div>
+
+              <button
+                type="button"
+                onClick={() => handleCopy(activeTone)}
+                className="cta-secondary rounded-lg px-3 py-1.5 text-xs font-medium inline-flex items-center gap-1.5"
+              >
+                {copied === activeTone ? (
+                  <><Check size={12} className="text-[#30D158]" /> Copied</>
+                ) : (
+                  <><Copy size={12} /> Copy</>
+                )}
+              </button>
+            </div>
+          </div>
+        )}
+      </div>
+    </div>
+  );
+};
+
+export default ListingDescription;
diff --git a/components/MLSExport.tsx b/components/MLSExport.tsx
new file mode 100644
index 0000000..11f6651
--- /dev/null
+++ b/components/MLSExport.tsx
@@ -0,0 +1,276 @@
+import React, { useState } from 'react';
+import { X, Download, Check, Image as ImageIcon, FileArchive } from 'lucide-react';
+import type { WatermarkConfig, BrandKit, MLSPreset } from '../types';
+import {
+  base64ToBlob,
+  resizeImage,
+  stripExif,
+  addWatermark,
+  exportAsZip,
+  downloadBlob,
+} from '../utils/imageExport';
+
+const MLS_PRESETS: MLSPreset[] = [
+  { label: 'Zillow / Realtor.com', width: 2048, height: 1536 },
+  { label: 'ARMLS', width: 2048, height: 1536 },
+  { label: 'Generic HD', width: 1920, height: 1080 },
+  { label: 'Generic Standard', width: 1280, height: 960 },
+];
+
+type WatermarkOption = 'text' | 'logo' | 'none';
+
+interface MLSExportProps {
+  images: { base64: string; roomLabel: string }[];
+  brandKit: BrandKit | null;
+  onClose: () => void;
+}
+
+const MLSExport: React.FC<MLSExportProps> = ({ images, brandKit, onClose }) => {
+  const [selectedPreset, setSelectedPreset] = useState(0);
+  const [watermarkOption, setWatermarkOption] = useState<WatermarkOption>('text');
+  const [selectedImages, setSelectedImages] = useState<Set<number>>(
+    () => new Set(images.map((_, i) => i)),
+  );
+  const [isExporting, setIsExporting] = useState(false);
+  const [progress, setProgress] = useState(0);
+
+  const hasLogo = !!(brandKit?.logo);
+  const preset = MLS_PRESETS[selectedPreset];
+  const allSelected = selectedImages.size === images.length;
+
+  const toggleImage = (idx: number) => {
+    setSelectedImages((prev) => {
+      const next = new Set(prev);
+      if (next.has(idx)) next.delete(idx);
+      else next.add(idx);
+      return next;
+    });
+  };
+
+  const toggleAll = () => {
+    if (allSelected) setSelectedImages(new Set());
+    else setSelectedImages(new Set(images.map((_, i) => i)));
+  };
+
+  const getWatermarkConfig = (): WatermarkConfig | null => {
+    if (watermarkOption === 'none') return null;
+    if (watermarkOption === 'logo' && hasLogo) {
+      return { type: 'logo', logoBase64: brandKit!.logo!, opacity: 0.7, position: 'bottom-right' };
+    }
+    return { type: 'text', text: 'Virtually Staged', opacity: 0.7, position: 'bottom-right' };
+  };
+
+  const processImage = async (base64: string): Promise<Blob> => {
+    let blob = base64ToBlob(base64);
+    blob = await stripExif(blob);
+    blob = await resizeImage(blob, preset.width, preset.height);
+    const wmConfig = getWatermarkConfig();
+    if (wmConfig) blob = await addWatermark(blob, wmConfig);
+    return blob;
+  };
+
+  const handleExportSingle = async (idx: number) => {
+    setIsExporting(true);
+    try {
+      const img = images[idx];
+      const blob = await processImage(img.base64);
+      const name = `${String(idx + 1).padStart(3, '0')}_${img.roomLabel.toLowerCase().replace(/\s+/g, '_')}_staged.jpg`;
+      downloadBlob(blob, name);
+    } catch (err) {
+      console.error('Export failed:', err);
+    } finally {
+      setIsExporting(false);
+    }
+  };
+
+  const handleExportZip = async () => {
+    const selected = [...selectedImages].sort((a: number, b: number) => a - b);
+    if (selected.length === 0) return;
+
+    setIsExporting(true);
+    setProgress(0);
+
+    try {
+      const files: { name: string; blob: Blob }[] = [];
+
+      for (let i = 0; i < selected.length; i++) {
+        const idx = selected[i];
+        const img = images[idx];
+        const blob = await processImage(img.base64);
+        const name = `${String(i + 1).padStart(3, '0')}_${img.roomLabel.toLowerCase().replace(/\s+/g, '_')}_staged.jpg`;
+        files.push({ name, blob });
+        setProgress(Math.round(((i + 1) / selected.length) * 100));
+      }
+
+      const zip = await exportAsZip(files);
+      downloadBlob(zip, `mls_export_${preset.label.replace(/\s+/g, '_').toLowerCase()}.zip`);
+    } catch (err) {
+      console.error('Zip export failed:', err);
+    } finally {
+      setIsExporting(false);
+      setProgress(0);
+    }
+  };
+
+  return (
+    <div className="fixed inset-0 z-[100] grid place-items-center modal-overlay p-4 animate-fade-in">
+      <div className="modal-panel w-full max-w-xl rounded-2xl p-6 animate-scale-in max-h-[90vh] overflow-y-auto scrollbar-hide">
+        {/* Header */}
+        <div className="flex items-start justify-between mb-5">
+          <div>
+            <span className="feature-badge feature-badge-primary mb-2">
+              <FileArchive size={13} /> MLS Export
+            </span>
+            <h3 className="font-display text-xl font-bold text-[var(--color-ink)]">Export for MLS</h3>
+            <p className="text-xs text-[var(--color-text)] mt-1">
+              Resize, strip metadata, and download MLS-ready images.
+            </p>
+          </div>
+          <button
+            type="button"
+            onClick={onClose}
+            className="rounded-lg p-2 text-[var(--color-text)] transition hover:bg-[var(--color-bg)]"
+          >
+            <X size={16} />
+          </button>
+        </div>
+
+        {/* Preset selector */}
+        <div className="mb-4">
+          <p className="text-xs font-semibold uppercase tracking-[0.1em] text-[var(--color-text)] mb-2">
+            MLS Platform
+          </p>
+          <div className="grid grid-cols-2 gap-2">
+            {MLS_PRESETS.map((p, i) => (
+              <button
+                key={p.label}
+                type="button"
+                onClick={() => setSelectedPreset(i)}
+                className={`rounded-xl border px-3 py-2.5 text-left transition-all ${
+                  selectedPreset === i
+                    ? 'border-[var(--color-primary)] bg-[rgba(10,132,255,0.1)] text-[var(--color-primary)]'
+                    : 'border-[var(--color-border)] text-[var(--color-text)] hover:border-[var(--color-border-strong)]'
+                }`}
+              >
+                <span className="text-xs font-semibold block">{p.label}</span>
+                <span className="text-[10px] opacity-60">{p.width} x {p.height}</span>
+              </button>
+            ))}
+          </div>
+        </div>
+
+        {/* Watermark */}
+        <div className="mb-4">
+          <p className="text-xs font-semibold uppercase tracking-[0.1em] text-[var(--color-text)] mb-2">
+            Watermark
+          </p>
+          <div className="flex gap-2">
+            {(['text', 'logo', 'none'] as WatermarkOption[]).map((opt) => {
+              const disabled = opt === 'logo' && !hasLogo;
+              return (
+                <button
+                  key={opt}
+                  type="button"
+                  disabled={disabled}
+                  onClick={() => setWatermarkOption(opt)}
+                  className={`rounded-lg px-3 py-1.5 text-xs font-medium border transition-all ${
+                    disabled
+                      ? 'opacity-30 cursor-not-allowed border-[var(--color-border)]'
+                      : watermarkOption === opt
+                        ? 'border-[var(--color-primary)] bg-[rgba(10,132,255,0.1)] text-[var(--color-primary)]'
+                        : 'border-[var(--color-border)] text-[var(--color-text)] hover:border-[var(--color-border-strong)]'
+                  }`}
+                >
+                  {opt === 'text' ? '"Virtually Staged"' : opt === 'logo' ? 'Agent Logo' : 'None'}
+                </button>
+              );
+            })}
+          </div>
+          {watermarkOption === 'logo' && !hasLogo && (
+            <p className="text-[10px] text-[var(--color-accent)] mt-1">Upload a logo in Brand Kit first.</p>
+          )}
+        </div>
+
+        {/* Image selection */}
+        <div className="mb-4">
+          <div className="flex items-center justify-between mb-2">
+            <p className="text-xs font-semibold uppercase tracking-[0.1em] text-[var(--color-text)]">
+              Images ({selectedImages.size}/{images.length})
+            </p>
+            <button
+              type="button"
+              onClick={toggleAll}
+              className="text-[10px] font-semibold text-[var(--color-primary)] hover:underline"
+            >
+              {allSelected ? 'Deselect All' : 'Select All'}
+            </button>
+          </div>
+          <div className="grid grid-cols-4 sm:grid-cols-5 gap-2 max-h-48 overflow-y-auto scrollbar-hide">
+            {images.map((img, i) => (
+              <button
+                key={i}
+                type="button"
+                onClick={() => toggleImage(i)}
+                className={`relative group rounded-lg overflow-hidden border aspect-[4/3] transition-all ${
+                  selectedImages.has(i)
+                    ? 'border-[var(--color-primary)] ring-2 ring-[var(--color-primary)]'
+                    : 'border-[var(--color-border)] opacity-50'
+                }`}
+              >
+                <img src={img.base64} alt={img.roomLabel} className="w-full h-full object-cover" />
+                {selectedImages.has(i) && (
+                  <div className="absolute top-1 right-1 w-5 h-5 rounded-full bg-[var(--color-primary)] flex items-center justify-center">
+                    <Check size={10} className="text-white" />
+                  </div>
+                )}
+                <div className="absolute bottom-0 inset-x-0 bg-gradient-to-t from-black/80 to-transparent p-1">
+                  <span className="text-[8px] font-medium text-white truncate block">{img.roomLabel}</span>
+                </div>
+              </button>
+            ))}
+          </div>
+        </div>
+
+        {/* Progress bar */}
+        {isExporting && progress > 0 && (
+          <div className="mb-4">
+            <div className="h-1.5 rounded-full bg-[var(--color-bg-deep)] overflow-hidden">
+              <div
+                className="h-full rounded-full bg-[var(--color-primary)] transition-all duration-300"
+                style={{ width: `${progress}%` }}
+              />
+            </div>
+            <p className="text-[10px] text-[var(--color-text)] mt-1 text-center">
+              Processing... {progress}%
+            </p>
+          </div>
+        )}
+
+        {/* Export buttons */}
+        <div className="flex gap-2">
+          <button
+            type="button"
+            onClick={handleExportZip}
+            disabled={isExporting || selectedImages.size === 0}
+            className="cta-primary flex-1 rounded-xl py-3 text-sm font-semibold inline-flex items-center justify-center gap-2 disabled:opacity-50"
+          >
+            <FileArchive size={15} />
+            {isExporting ? 'Exporting...' : `Download ZIP (${selectedImages.size})`}
+          </button>
+          {images.length === 1 && (
+            <button
+              type="button"
+              onClick={() => handleExportSingle(0)}
+              disabled={isExporting}
+              className="cta-secondary rounded-xl px-4 py-3 text-sm font-medium inline-flex items-center gap-2 disabled:opacity-50"
+            >
+              <Download size={15} /> Single
+            </button>
+          )}
+        </div>
+      </div>
+    </div>
+  );
+};
+
+export default MLSExport;
