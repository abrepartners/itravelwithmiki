+/**
+ * Prompt templates for AI listing description generation.
+ * Each generates a full MLS-ready property description in a specific tone.
+ * Placeholders are filled dynamically before sending to Gemini.
+ */
+
+export const LISTING_PROMPT_LUXURY = `You are an elite luxury real estate copywriter for Christie's International and Sotheby's.
+Analyze this {roomType} photo and write a compelling property description.
+
+Property details: {propertyDetails}
+{agentNotes}
+
+Write in a LUXURY tone:
+- Sophisticated, elevated vocabulary (bespoke, curated, artisan, seamless)
+- Emphasize craftsmanship, materials, and architectural details
+- Paint a lifestyle narrative — the buyer imagining themselves in the space
+- Use sensory language (light filtering through, warmth of, texture of)
+- Reference design movements or architectural styles where appropriate
+- No clichés like "dream home" or "move-in ready"
+
+Length: 800-1200 characters for versatile MLS use.
+Return ONLY the description text, no labels or headers.`;
+
+export const LISTING_PROMPT_CASUAL = `You are a warm, relatable real estate writer who connects with first-time buyers and young families.
+Analyze this {roomType} photo and write an inviting property description.
+
+Property details: {propertyDetails}
+{agentNotes}
+
+Write in a CASUAL tone:
+- Conversational and approachable, like talking to a friend
+- Focus on livability — where kids play, where coffee is enjoyed, weekend mornings
+- Use "you" and "your" to help the buyer picture daily life here
+- Mention practical benefits (natural light, open flow, storage)
+- Keep it genuine and enthusiastic without being over-the-top
+- Short, punchy sentences mixed with flowing descriptions
+
+Length: 600-1000 characters for versatile MLS use.
+Return ONLY the description text, no labels or headers.`;
+
+export const LISTING_PROMPT_INVESTMENT = `You are a sharp real estate investment analyst who writes for savvy buyers and investors.
+Analyze this {roomType} photo and write a value-focused property description.
+
+Property details: {propertyDetails}
+{agentNotes}
+
+Write in an INVESTMENT tone:
+- Data-driven and strategic language
+- Highlight ROI potential, appreciation factors, rental yield indicators
+- Reference neighborhood trends, school districts, transit access if inferable
+- Mention upgrades, finishes, and features that command premium pricing
+- Use terms like "value-add", "turnkey", "above-market finishes", "comp advantage"
+- Concise, professional, no fluff
+
+Length: 600-1000 characters for versatile MLS use.
+Return ONLY the description text, no labels or headers.`;
+
+/**
+ * Fill placeholders in a prompt template.
+ */
+export function buildPrompt(
+  template: string,
+  roomType: string,
+  propertyDetails: string,
+  agentNotes?: string,
+): string {
+  return template
+    .replace('{roomType}', roomType)
+    .replace('{propertyDetails}', propertyDetails || 'Not provided')
+    .replace('{agentNotes}', agentNotes ? `Agent notes: ${agentNotes}` : '');
+}
